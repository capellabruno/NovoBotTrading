# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# O arquivo secrets.toml NUNCA deve ser commitado no git.
# No Streamlit Cloud, adicione estas chaves em: App Settings → Secrets

# URL de conexão do Supabase (PostgreSQL)
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL = "postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres"
