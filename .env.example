# NovoBotTrading - Template de Credenciais
# Copie este arquivo para .env e preencha com suas chaves reais

# --- Bybit ---
BYBIT_API_KEY=sua_api_key_aqui
BYBIT_API_SECRET=seu_api_secret_aqui

# --- Telegram ---
TELEGRAM_TOKEN=seu_telegram_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# --- LLM (MCP) ---
GEMINI_API_KEY=sua_gemini_api_key_aqui
GROQ_API_KEY=sua_groq_api_key_aqui

# --- Banco de Dados ---
# Deixe vazio para usar SQLite local.
# No Railway/Supabase, preencha com a connection string do PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# --- Modo de execução ---
# true  = simulação (sem ordens reais na Bybit)
# false = live (ordens reais) — padrão do settings.yaml
DRY_RUN=false
